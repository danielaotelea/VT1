OPENAI_API_KEY=sk-...

# ── LangWatch (default exporter) ─────────────────────────────────────────────
LANGWATCH_API_KEY=...

# ── Langfuse (local Docker Compose on port 3000) ──────────────────────────────
# After `docker compose up` in the langfuse repo, create a project in the UI
# to get these keys.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# ── Arize Phoenix (local, no key needed) ─────────────────────────────────────
# Phoenix auto-starts via px.launch_app() when exporter="phoenix".
# If running the standalone server instead, set:
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317

# ── Comet Opik (local Docker Compose) ────────────────────────────────────────
# After `docker compose up` in the opik repo, no API key is needed for local.
# OPIK_URL_OVERRIDE=http://localhost:5173/api
# OPIK_PROJECT_NAME=vt1-agent

# ── ResearcherAgent web search (pick one) ────────────────────────────────────
# TAVILY_API_KEY=...
# (DuckDuckGo is used as fallback when TAVILY_API_KEY is not set — no key needed)
